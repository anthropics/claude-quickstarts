{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "AGI HPC Dashboard",
  "uid": "agi-hpc-v1",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["agi", "hpc", "slurm", "apptainer"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "{{gpu}} {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "GPU Memory Used (MiB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "{{gpu}} {{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "id": 3,
      "title": "Slurm — Running Jobs",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slurm_jobs_running", "legendFormat": "Running" }
      ]
    },
    {
      "id": 4,
      "title": "Slurm — Pending Jobs",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slurm_jobs_pending", "legendFormat": "Pending" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Preemptions / hour",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(slurm_jobs_preempted_total[1h]) * 3600",
          "legendFormat": "Preemptions/hr"
        }
      ]
    },
    {
      "id": 6,
      "title": "InfiniBand — Port TX Bandwidth (Gbps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(node_infiniband_port_data_transmitted_bytes_total[1m]) * 8 / 1e9",
          "legendFormat": "{{device}} port {{port}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Gbps" } }
    },
    {
      "id": 7,
      "title": "InfiniBand — Port Errors",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(node_infiniband_port_excessive_buffer_overrun_errors_total[1m])",
          "legendFormat": "buffer_overrun {{device}}"
        },
        {
          "expr": "rate(node_infiniband_port_link_error_recovery_total[1m])",
          "legendFormat": "link_recovery {{device}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Apptainer — Active Containers",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "apptainer_instances_running", "legendFormat": "Containers" }
      ]
    },
    {
      "id": 9,
      "title": "LLM Cascade — Draft Hit Rate (%)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "singularity_cascade_draft_hit_rate * 100",
          "legendFormat": "Draft Hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    }
  ]
}
