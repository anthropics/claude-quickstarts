# ── Required ──────────────────────────────────────────────────────────────
# Fernet key for encrypting API keys at rest in SQLite.
# Generate a new one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_SECRET_KEY=

# ── Anthropic API ──────────────────────────────────────────────────────────
# Used as a fallback; users can also supply their key in the UI per-session.
ANTHROPIC_API_KEY=

# ── Display size (optional) ────────────────────────────────────────────────
WIDTH=1024
HEIGHT=768

# ── AWS Bedrock (optional) ─────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Google Vertex (optional) ───────────────────────────────────────────────
CLOUD_ML_REGION=
ANTHROPIC_VERTEX_PROJECT_ID=
