// Cloudflare Workers config. Deploy is `npx wrangler deploy` -- the build
// hook below runs `npm run build` for you (same for `wrangler dev`). Set the
// secrets first: `wrangler secret put` ANTHROPIC_API_KEY, CLAUDE_AGENT_ID,
// and CLAUDE_ENVIRONMENT_ID. nodejs_compat surfaces them as process.env;
// that needs a compatibility_date of 2025-04-01 or later (see the note in
// src/worker.ts).
{
  "name": "chat-sdk-research-analyst",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "build": { "command": "npm run build" },
  "assets": {
    "directory": "./public",
    // Static assets answer first; only /api/* reaches the Worker.
    "run_worker_first": ["/api/*"]
  }
}
