   "source": [
    "# Trading prototype - Colab backtest\n",
    "\n",
    "This notebook installs dependencies, runs a simple SMA crossover backtest for AAPL, and writes CSV/PNG/HTML results.\n",
    "Open `Runtime -> Run all` to execute."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install dependencies\n",
    "!pip install --quiet backtrader yfinance pandas matplotlib\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import backtrader as bt\n",
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import csv, os\n",
    "from datetime import datetime\n",
    "\n",
    "# Strategy (SMA crossover)\n",
    "class SmaCross(bt.Strategy):\n",
    "    params = dict(short_period=10, long_period=30, stake=10, slippage=0.001)\n",
    "\n",
    "    def __init__(self):\n",
    "        self.sma_short = bt.indicators.SimpleMovingAverage(self.datas[0], period=self.p.short_period)\n",
    "        self.sma_long = bt.indicators.SimpleMovingAverage(self.datas[0], period=self.p.long_period)\n",
    "        self.crossover = bt.indicators.CrossOver(self.sma_short, self.sma_long)\n",
    "        self.total_commission = 0.0\n",
    "        self.total_slippage = 0.0\n",
    "        self.total_volume = 0\n",
    "        self.trade_count = 0\n",
    "        self.exec_log = []\n",
    "        self.trade_summaries = []\n",
    "        self.portfolio_history = []\n",
    "\n",
    "    def log(self, txt):\n",
    "        print(txt)\n",
    "\n",
    "    def next(self):\n",
    "        if not self.position:\n",
    "            if self.crossover > 0:\n",
    "                self.log(f\"BUY  {self.datas[0].datetime.date(0)} Close={self.datas[0].close[0]:.2f}\")\n",
    "                self.buy(size=self.p.stake, price=self.datas[0].close[0] * (1 + self.p.slippage), exectype=bt.Order.Limit)\n",
    "        else:\n",
    "            if self.crossover < 0:\n",
    "                self.log(f\"SELL {self.datas[0].datetime.date(0)} Close={self.datas[0].close[0]:.2f}\")\n",
    "                self.close(price=self.datas[0].close[0] * (1 - self.p.slippage), exectype=bt.Order.Limit)\n",
    "\n",
    "        try:\n",
    "            ts = getattr(self.datas[0].datetime, 'date')(0).isoformat()\n",
    "        except Exception:\n",
    "            try:\n",
    "                ts = str(self.datas[0].datetime.datetime(0))\n",
    "            except Exception:\n",
    "                ts = ''\n",
    "        try:\n",
    "            value = float(self.broker.getvalue())\n",
    "        except Exception:\n",
    "            value = 0.0\n",
    "        self.portfolio_history.append({'timestamp': ts, 'value': value})\n",
    "\n",
    "    def notify_order(self, order):\n",
    "        if order.status == bt.Order.Completed:\n",
    "            executed = getattr(order, 'executed', None)\n",
    "            if executed:\n",
    "                price = getattr(executed, 'price', 0.0) or 0.0\n",
    "                size = getattr(executed, 'size', 0) or 0\n",
    "                comm = getattr(executed, 'comm', 0.0) or 0.0\n",
    "                try:\n",
    "                    current_close = float(self.datas[0].close[0])\n",
    "                except Exception:\n",
    "                    current_close = price\n",
    "                slippage_cost = abs(price - current_close) * abs(size)\n",
    "                self.total_slippage += slippage_cost\n",
    "                self.total_commission += comm\n",
    "                self.total_volume += abs(size)\n",
    "                try:\n",
    "                    side = 'buy' if order.isbuy() else 'sell'\n",
    "                except Exception:\n",
    "                    side = 'buy' if size > 0 else 'sell'\n",
    "                try:\n",
    "                    ts = getattr(self.datas[0].datetime, 'date')(0).isoformat()\n",
    "                except Exception:\n",
    "                    try:\n",
    "                        ts = str(self.datas[0].datetime.datetime(0))\n",
    "                    except Exception:\n",
    "                        ts = ''\n",
    "                entry = {'timestamp': ts, 'side': side, 'price': float(price), 'size': float(size), 'commission': float(comm), 'slippage_cost': float(slippage_cost)}\n",
    "                self.exec_log.append(entry)\n",
    "                self.log(f\"Order executed: {side} price={price:.2f} size={size} comm={comm:.4f} slippage_cost={slippage_cost:.4f}\")\n",
    "\n",
    "    def notify_trade(self, trade):\n",
    "        if trade.isclosed:\n",
    "            self.trade_count += 1\n",
    "            try:\n",
    "                close_ts = getattr(self.datas[0].datetime, 'date')(0).isoformat()\n",
    "            except Exception:\n",
    "                close_ts = ''\n",
    "            summary = {'close_date': close_ts, 'pnl': float(trade.pnl) if hasattr(trade, 'pnl') else 0.0, 'pnl_comm': float(trade.pnlcomm) if hasattr(trade, 'pnlcomm') else 0.0}\n",
    "            self.trade_summaries.append(summary)\n",
    "            self.log(f\"Trade closed, PnL Gross {trade.pnl:.2f}\")\n",
    "\n",
    "    def stop(self):\n",
    "        self.log(f\"Total trades: {self.trade_count}\")\n",
    "        self.log(f\"Total commission: {self.total_commission:.4f}\")\n",
    "        self.log(f\"Total slippage cost: {self.total_slippage:.4f}\")\n",
    "        self.log(f\"Total volume traded: {self.total_volume}\")\n",
    "\n",
    "# Backtest runner and reporting\n",
    "def run_backtest(ticker='AAPL', start='2020-01-01', end='2024-01-01', cash=100, commission=0.002, slippage=0.001):\n",
    "    print(f'Downloading {ticker}...')\n",
    "    df = yf.download(ticker, start=start, end=end, progress=False)\n",
    "    if df.empty:\n",
    "        raise SystemExit('No data downloaded')\n",
    "    df.index = pd.to_datetime(df.index)\n",
    "    cerebro = bt.Cerebro()\n",
    "    cerebro.broker.setcash(cash)\n",
    "    cerebro.broker.setcommission(commission=commission)\n",
    "    cerebro.addstrategy(SmaCross, slippage=slippage)\n",
    "    data = bt.feeds.PandasData(dataname=df)\n",
    "    cerebro.adddata(data)\n",
    "    print(f'Starting value: {cerebro.broker.getvalue():.2f}')\n",
    "    results = cerebro.run()\n",
    "    print(f'Final value: {cerebro.broker.getvalue():.2f}')\n",
    "\n",
    "    strat = results[0]\n",
    "    timestamp = datetime.utcnow().strftime('%Y%m%dT%H%M%SZ')\n",
    "    results_dir = '/content/trading_results'\n",
    "    os.makedirs(results_dir, exist_ok=True)\n",
    "    base = f'{results_dir}/results_{ticker.replace('/','_')}_{timestamp}'\n",
    "    # CSVs\n",
    "    exec_log = getattr(strat, 'exec_log', [])\n",
    "    trade_summaries = getattr(strat, 'trade_summaries', [])\n",
    "    portfolio_history = getattr(strat, 'portfolio_history', [])\n",
    "    if exec_log:\n",
    "        exec_file = base + '_executions.csv'\n",
    "        with open(exec_file, 'w', newline='') as f:\n",
    "            writer = csv.DictWriter(f, fieldnames=['timestamp','side','price','size','commission','slippage_cost'])\n",
    "            writer.writeheader()\n",
    "            for row in exec_log:\n",
    "                writer.writerow(row)\n",
    "        print('Saved', exec_file)\n",
    "    if trade_summaries:\n",
    "        summary_file = base + '_trades.csv'\n",
    "        with open(summary_file, 'w', newline='') as f:\n",
    "            writer = csv.DictWriter(f, fieldnames=['close_date','pnl','pnl_comm'])\n",
    "            writer.writeheader()\n",
    "            for row in trade_summaries:\n",
    "                writer.writerow(row)\n",
    "        print('Saved', summary_file)\n",
    "    # Equity plot\n",
    "    if portfolio_history:\n",
    "        ph_df = pd.DataFrame(portfolio_history)\n",
    "        try:\n",
    "            ph_df['timestamp'] = pd.to_datetime(ph_df['timestamp'])\n",
    "        except Exception:\n",
    "            pass\n",
    "        plt.figure(figsize=(10,4))\n",
    "        plt.plot(ph_df['timestamp'], ph_df['value'], marker='.', linewidth=1)\n",
    "        plt.title(f'Equity Curve - {ticker}')\n",
    "        plt.xlabel('Date')\n",
    "        plt.ylabel('Portfolio Value')\n",
    "        plt.grid(True)\n",
    "        png_file = base + '_equity.png'\n",
    "        plt.tight_layout()\n",
    "        plt.savefig(png_file)\n",
    "        plt.close()\n",
    "        print('Saved', png_file)\n",
    "    # HTML report\n",
    "    report_file = base + '_report.html'\n",
    "    with open(report_file, 'w') as f:\n",
    "        f.write('<html><head><meta charset="utf-8"><title>Backtest Report</title></head><body>')\n",
    "        f.write(f'<h1>Backtest Report - {ticker}</h1>')\n",
    "        f.write(f'<p>Start: {start} &nbsp; End: {end} &nbsp; Starting Cash: {cash}</p>')\n",
    "        f.write('<h2>Summary</h2>')\n",
    "        f.write(f'<p>Final Portfolio Value: {cerebro.broker.getvalue():.2f}</p>')\n",
    "        f.write(f'<p>Trades closed: {getattr(strat, "trade_count", 0)}</p>')\n",
    "        f.write(f'<p>Total commission paid: {getattr(strat, "total_commission", 0.0):.4f}</p>')\n",
    "        f.write(f'<p>Total slippage cost: {getattr(strat, "total_slippage", 0.0):.4f}</p>')\n",
    "        if portfolio_history:\n",
    "            f.write('<h2>Equity Curve</h2>')\n",
    "            f.write(f'<img src="{os.path.basename(png_file)}" alt="equity" style="max-width:100%;height:auto;">')\n",
    "        if exec_log:\n",
    "            f.write('<h2>Execution Log</h2>')\n",
    "            f.write(f'<p><a href="{os.path.basename(exec_file)}">Download executions CSV</a></p>')\n",
    "        if trade_summaries:\n",
    "            f.write('<h2>Trade Summaries</h2>')\n",
    "            f.write(f'<p><a href="{os.path.basename(summary_file)}">Download trade summaries CSV</a></p>')\n",
    "        f.write('</body></html>')\n",
    "    print('Report saved to', report_file)\n",
    "    return {'exec': exec_log, 'trades': trade_summaries, 'report': report_file, 'png': png_file if portfolio_history else None}\n",
    "\n",
    "# Run example\n",
    "res = run_backtest('AAPL','2020-01-01','2024-01-01')\n",
    "res\n"
   ]
  }
 ],
