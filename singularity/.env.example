# ── Claude (Anthropic) — povinný ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
PRIMARY_CLOUD_MODEL=claude-sonnet-4-6

# ── Google Gemini — volitelný ─────────────────────────────────
# Pokud chybí, router degraduje na čistě Claude režim.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ENABLE_GEMINI=true

# ── LLM Routing ───────────────────────────────────────────────
# static | failover | round_robin | cost_optimized | latency_optimized | quality_first
ROUTING_STRATEGY=static

# ── Paměť — volitelné ─────────────────────────────────────────
# Bez klíčů běží lokální ChromaDB + offline hash embeddings.
OPENAI_API_KEY=
MEM0_API_KEY=
CHROMA_PERSIST_DIR=./data/chroma

# ── Bezpečnost ────────────────────────────────────────────────
MAX_ITERATIONS=10
REQUIRE_HUMAN_APPROVAL=true
RISK_THRESHOLD=0.7

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
