# Copy to .env for local overrides. The server scripts load it via
# --env-file-if-exists, and the web build reads it from this directory.

# --- Credentials -------------------------------------------------------------
# Optional locally (the SDK also resolves an `ant auth login` profile).
# Required on deployment platforms.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Agent identity ----------------------------------------------------------
# `npm run setup` writes agent-ids.json and the server reads it from disk.
# On platforms without a persistent checkout (Vercel, Netlify, containers),
# set these three instead. Setup prints them, and re-running it prints them
# again. All three set: they take precedence over agent-ids.json. Only some
# set: boot error.
# ANTHROPIC_ENVIRONMENT_ID=env_...
# ANTHROPIC_AGENT_ID=agent_...
# ANTHROPIC_AGENT_VERSION=1

# --- Server ------------------------------------------------------------------
# Bridge server port (default 8787). In dev, the Vite proxy target in
# web/vite.config.ts must match.
# PORT=8787

# Comma-separated origins allowed to call the runtime. Unset = allow all,
# which is fine locally but not on a public deployment (the endpoint spends
# your API credits). Set but empty = deny cross-origin.
# ALLOWED_ORIGINS=https://your-frontend.example.com

# --- Web (build time) --------------------------------------------------------
# Only when the frontend is hosted separately from the server. Baked into the
# bundle by `npm run build`. Unset = same-origin /api/copilotkit.
# VITE_COPILOT_RUNTIME_URL=https://your-server.example.com/api/copilotkit
